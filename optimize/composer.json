{
     "version": "1.0.0",
    "name": "alphasky/optimize",
    "description": "Optimize page speed package",
    "type": "package",
    "autoload": {
        "psr-4": {
            "Alphasky\\Optimize\\": "src"
        }
    },
    "require": {
        "alphasky/platform": "1.0.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alphasky\\Optimize\\Providers\\OptimizeServiceProvider"
            ],
            "aliases": {
                "OptimizerHelper": "Alphasky\\Optimize\\Facades\\OptimizerHelper"
            }
        }
    }
}
