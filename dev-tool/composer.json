{
        "version": "1.0.0",
    "name": "alphasky/dev-tool",
    "description": "Dev tool commands for Alphasky CMS",
    "type": "package",
    "license": "MIT",
    "keywords": [
        "alphasky",
        "alphasky cms",
        "alphasky platform",
        "alphasky dev tools"
    ],
    "homepage": "https://alphasky.org",
    "authors": [
        {
            "name": "Alphasky Technologies",
            "email": "contact@alphasky.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "Alphasky\\DevTool\\": "src"
        }
    },
    "require": {
        "laravel/framework": "^10.31|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.5.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alphasky\\DevTool\\Providers\\DevToolServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
