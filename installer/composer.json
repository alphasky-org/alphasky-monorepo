{
     "version": "1.0.0",
    "name": "alphasky/installer",
    "description": "Installer package for Alphasky CMS application",
    "type": "package",
    "autoload": {
        "psr-4": {
            "Alphasky\\Installer\\": "src"
        }
    },
    "require": {
        "alphasky/platform": "1.0.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alphasky\\Installer\\Providers\\InstallerServiceProvider"
            ]
        }
    }
}
