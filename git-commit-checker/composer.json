{
    "version": "1.0.0",
  "name": "alphasky/git-commit-checker",
  "description": "Check coding standard & code syntax with Git pre-commit hook.",
  "type": "package",
  "license": "MIT",
  "keywords": [
    "alphasky",
    "alphasky cms",
    "alphasky platform",
    "alphasky git commit checker"
  ],
  "homepage": "https://alphasky.org",
  "authors": [
    {
      "name": "Bassam Alessawi",
      "email": "bassam.alessawi@icloud.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Alphasky\\GitCommitChecker\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alphasky\\GitCommitChecker\\Tests\\": "tests"
    }
  },
  "require": {
    "php": "^8.0|^8.1|^8.2|^8.3",
    "laravel/framework": ">=9.32",
    "laravel/pint": "^1.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0|^10.0|^11.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Alphasky\\GitCommitChecker\\Providers\\GitCommitCheckerServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
